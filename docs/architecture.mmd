%% ============================================================
%% 2. System Architecture (Component Diagram)
%% ============================================================

---
title: System Architecture
---

graph TB
    subgraph Client["Browser (SPA)"]
        FE["static/index.html<br/>Leaflet Map + Dashboard"]
    end

    subgraph CloudRun_CPU["Cloud Run — CPU Service"]
        APP["FastAPI App<br/>app/main.py"]
        subgraph Routers
            AUTH_R["auth.py<br/>/api/auth/*"]
            INF_R["inference.py<br/>/api/inference/*"]
            JOBS_R["jobs.py<br/>/api/jobs/*"]
            ADMIN_R["admin.py<br/>/api/admin/*"]
        end
        subgraph Core
            CONFIG["config.py<br/>pydantic-settings"]
            AUTH_C["auth.py<br/>JWT create/decode"]
            INF_C["inference.py<br/>YOLO ONNX pipeline"]
            LC_C["land_cover_inference.py<br/>SwinUnet pipeline"]
            FS_C["firestore_client.py<br/>Users + Jobs CRUD"]
        end
        subgraph Middleware
            AUTH_M["auth.py<br/>get_current_user<br/>require_role"]
        end
    end

    subgraph CloudRun_GPU["Cloud Run — GPU Service (optional)"]
        GPU["Palm Counter GPU<br/>NVIDIA L4"]
    end

    subgraph GCP["Google Cloud Platform"]
        FIRESTORE[("Firestore<br/>users / jobs")]
        GCS[("Cloud Storage<br/>uploads / results / models")]
        GOOGLE["Google OAuth 2.0"]
    end

    FE -->|"REST API + JWT"| APP
    APP --> AUTH_R & INF_R & JOBS_R & ADMIN_R
    AUTH_R --> AUTH_C
    AUTH_R --> FS_C
    AUTH_R -->|"OAuth code exchange"| GOOGLE
    INF_R --> INF_C & LC_C
    INF_R --> FS_C
    INF_R -->|"Route large jobs"| GPU
    JOBS_R --> INF_C & LC_C
    JOBS_R --> FS_C
    ADMIN_R --> FS_C
    AUTH_M -.->|"Depends()"| AUTH_R & INF_R & JOBS_R & ADMIN_R
    FS_C --> FIRESTORE
    INF_C -->|"Read/write files"| GCS
    LC_C -->|"Read/write files"| GCS
    FE -->|"Direct upload (signed URL)"| GCS
    GPU -->|"Read rasters"| GCS
    GPU -->|"Write results"| GCS

    CONFIG -.->|"env vars"| AUTH_C & FS_C & INF_R

