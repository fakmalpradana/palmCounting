# ============================================================
# .gcloudignore — Palm Counter
#
# This file controls what gcloud excludes when uploading source
# to Cloud Build via `gcloud builds submit`.
#
# The root models/ directory is excluded (weights downloaded from GCS
# during Cloud Build Step 1). However, app/models/default/ is NOT
# excluded — Cloud Build copies the default model there (Step 1c) so
# it is baked into the Docker image and survives scale-to-zero.
#
# Note: .dockerignore is used by Docker itself; .gcloudignore is
# used only by the gcloud CLI source upload step.
# ============================================================

# Use all rules from .gitignore
.gcloudignore
.git/
.gitignore

# Python cache
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment / secrets
.env

# Large geodata (not needed in build)
*.tif
*.tiff
uploads/
output/
results/
data/

# Root-level model weights — downloaded from GCS during Cloud Build (see cloudbuild.yaml).
# Use a leading slash so this only excludes /models/ at the project root,
# NOT app/models/default/ which contains the baked-in default bundle.
/models/

# Dev-only scripts
install_*.sh
install_*.bat

# IDE / OS
.DS_Store
.idea/
.vscode/
